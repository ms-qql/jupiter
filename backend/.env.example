# Jupiter Backend — Beispiel-Umgebung. Kopiere nach `.env` (wird nicht committet).
# Jupiter-eigene Settings tragen den Prefix JUPITER_ (pydantic-settings, app/config.py).

# --- Engines (PROJ-18) ----------------------------------------------------
# Pfad der Engine-Registry (weitere Engines / iFrames / Launch-Einträge). Fehlt sie,
# läuft Jupiter nur mit der eingebauten Claude-Engine. Vorlage: config/engines.example.yaml.
# JUPITER_ENGINES_CONFIG_PATH=/home/dev/projects/jupiter/backend/config/engines.yaml

# API-Key der OpenAI-Engine (erste Test-Engine, driver: openai). NUR serverseitig — erreicht
# NIE das Frontend. Der Variablenname wird in engines.yaml über `auth_env` referenziert.
# Fehlt der Key, wird die Engine im Smart Launcher ausgegraut (klarer Setup-Hinweis).
OPENAI_API_KEY=sk-dummy-replace-me

# API-Key der OpenRouter-Engine (zweite Test-Engine). OpenRouter ist OpenAI-API-kompatibel
# und läuft über DENSELBEN `openai`-Treiber (anderer api_base/auth_env). Gleiche Regeln:
# nur serverseitig, in engines.yaml über `auth_env` referenziert, fehlt er → Engine ausgegraut.
OPENROUTER_API_KEY=sk-or-dummy-replace-me

# --- Spracheingabe / Push-to-Talk (PROJ-20) -------------------------------
# Standard ist self-hosted faster-whisper (lokal, kein Key nötig). Modellgröße +
# Sprache optional übersteuerbar (Default small / de).
# JUPITER_WHISPER_MODEL=small
# JUPITER_WHISPER_LANGUAGE=de
# Optionaler Groq-Cloud-Fallback (pay-per-use). NUR serverseitig — erreicht nie das
# Frontend. Fehlt der Key, ist der Cloud-Fallback im „Sprache"-Tab ausgegraut und die
# Transkription bleibt lokal. Erst zusammen mit JUPITER_USE_GROQ_TRANSCRIPTION=true aktiv.
# JUPITER_GROQ_API_KEY=gsk-dummy-replace-me
# JUPITER_USE_GROQ_TRANSCRIPTION=false
